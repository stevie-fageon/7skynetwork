# =====================================================================
# 7skynetwork — Environment variables
# Copy this file to ".env.local" for local development, and add the
# same variables in your Vercel project settings (see README.md).
# =====================================================================

# Resend API key — create a free account at https://resend.com
# Dashboard → API Keys → Create API Key → copy the "re_..." key here.
RESEND_API_KEY=re_your_api_key_here

# Email address where contact form messages are delivered (your inbox).
CONTACT_EMAIL=hello@7skynetwork.net

# "From" address used to send the emails. On the free Resend plan you
# MUST verify your sending domain (7skynetwork.net). Until it is
# verified, use the Resend sandbox address below for testing:
RESEND_FROM_EMAIL=onboarding@resend.dev
# Once your domain is verified, switch to:
# RESEND_FROM_EMAIL=website@7skynetwork.net
